#!/bin/sh
set -eu

output=${1:-.portway-tls}
hostname=${2:-localhost}
ip=${3:-127.0.0.1}

if ! command -v openssl >/dev/null 2>&1; then
  echo "openssl is required" >&2
  exit 1
fi

mkdir -p "$output"
chmod 700 "$output"
openssl req -x509 -newkey rsa:2048 -sha256 -nodes -days 7 \
  -keyout "$output/key.pem" \
  -out "$output/cert.pem" \
  -subj "/CN=$hostname" \
  -addext "subjectAltName=DNS:$hostname,IP:$ip" \
  -addext "keyUsage=digitalSignature,keyEncipherment" \
  -addext "extendedKeyUsage=serverAuth"
chmod 600 "$output/key.pem"
chmod 644 "$output/cert.pem"

printf 'Test certificate: %s/cert.pem\n' "$output"
printf 'Private key:      %s/key.pem\n' "$output"
printf 'Valid for seven days; use only for local TLS smoke tests.\n'
